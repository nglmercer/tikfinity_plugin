{
  "name": "browserapi",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.5.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun && bun build scripts/tikfinity-webview.ts --outdir dist/scripts --target bun",
    "build:exe": "bun build --compile src/index.ts --outfile ./dist/tikfinity"
  },
  "dependencies": {
    "arktype": "^2.1.29",
    "bun_plugins": "^1.2.5",
    "cheerio": "^1.2.0",
    "tiktok-live-connector": "^2.1.1-beta1",
    "trigger_system": "^1.3.1",
    "webview-napi": "^0.1.9"
  }
}
